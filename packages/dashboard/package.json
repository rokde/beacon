{
  "name": "@beacon/dashboard-assets",
  "version": "1.0.0",
  "private": true,
  "description": "Beacon Dashboard — frontend asset pipeline",
  "scripts": {
    "dev":            "vite",
    "build":          "vite build",
    "build:watch":    "vite build --watch",
    "typecheck":      "tsc --noEmit",
    "lint":           "oxlint --config oxlint.json resources/ts",
    "lint:fix":       "oxlint --config oxlint.json --fix resources/ts",
    "format":         "prettier --write resources/ts resources/css",
    "format:check":   "prettier --check resources/ts resources/css",
    "ci": [
      "npm run format:check",
      "npm run lint",
      "npm run typecheck",
      "npm run build"
    ]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "autoprefixer": "^10.5.2",
    "oxlint": "^1.72.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.6.0",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "chart.js": "^4.4.0"
  }
}
